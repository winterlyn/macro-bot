# ── Gemini ────────────────────────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# ── Telegram ──────────────────────────────────────────────────────────────
# Token dari BotFather (contoh format: 123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ)
TELEGRAM_BOT_TOKEN=8666004200:AAGDN6i1QovtNFwCmVZ3e5-zCUgkCVBAyeU

# String random 32 karakter — generate dengan: python -c "import secrets; print(secrets.token_hex(16))"
TELEGRAM_WEBHOOK_SECRET=247543418d211d0320c8b21af770fa0e634cdaae67a5fcf74e73514e14119cc3h

# Integer — cari user ID kamu via @userinfobot di Telegram
MY_TELEGRAM_USER_ID=6497603528

# ── Railway ───────────────────────────────────────────────────────────────
# Isi setelah deploy dan dapat URL (contoh: https://macro-bot-xxx.up.railway.app)
RAILWAY_PUBLIC_URL=web-production-2d4e1.up.railway.app

# Port yang digunakan uvicorn (Railway set ini otomatis, tidak perlu diubah)
PORT=8000