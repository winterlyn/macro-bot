# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Telegram ──────────────────────────────────────────────────────────────
# Token dari BotFather
TELEGRAM_BOT_TOKEN=

# String random 32 karakter — gunakan: python -c "import secrets; print(secrets.token_hex(16))"
TELEGRAM_WEBHOOK_SECRET=

# Integer — cari user ID kamu via @userinfobot di Telegram
MY_TELEGRAM_USER_ID=

# ── Railway ───────────────────────────────────────────────────────────────
# Isi setelah deploy dan dapat URL (contoh: https://macro-bot-xxx.up.railway.app)
RAILWAY_PUBLIC_URL=

# Port yang digunakan uvicorn (Railway set ini otomatis, tidak perlu diubah)
PORT=8000
